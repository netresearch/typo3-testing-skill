[
  {
    "name": "setup-unit-tests",
    "prompt": "Set up unit tests for this TYPO3 extension",
    "assertions": [
      {
        "type": "tool_use",
        "tool": "Glob",
        "description": "Scans for existing test infrastructure"
      },
      {
        "type": "content_contains",
        "value": "phpunit",
        "description": "References PHPUnit configuration"
      }
    ]
  },
  {
    "name": "add-functional-tests",
    "prompt": "Add functional tests for this repository",
    "assertions": [
      {
        "type": "tool_use",
        "tool": "Read",
        "description": "Reads existing code to generate tests"
      },
      {
        "type": "content_contains",
        "value": "FunctionalTestCase",
        "description": "Uses TYPO3 FunctionalTestCase base class"
      }
    ]
  }
]
